---
import CompetencyBar from "./CompetencyBar.astro";
import ProgressBar from "./ProgressBar.astro";
import ScoreEvolutionChart from "./ScoreEvolutionChart.astro";
import GraficProgressIcon from "../../icons/graficProgress.svg";

interface Competency {
  label: string;
  value: number;
  max: number;
}

interface ScoreHistoryItem {
  day: number
  date: string
  total: number
  essays: {
    theme: string
    total: number
  }[]
}

interface Props {
  competencies: Competency[];
  overallProgress: number;
  evolutionTotal: number;
  scoreHistory: ScoreHistoryItem[];
}

const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth(); // 0–11

const {
  competencies,
  overallProgress,
  evolutionTotal,
  scoreHistory = [],
} = Astro.props;

/* ---------------------------------------
   Converte scoreHistory em estrutura
   temporal (dia do mês real)
---------------------------------------- */

const chartData = scoreHistory.map((item) => ({
  day: item.day,
  date: item.date,
  total: item.total,
  essays: item.essays
}));
---

<section class="mb-12">
  <div class="glass-card p-8">

    {/* ---------------- HEADER ---------------- */}

    <div class="flex justify-between items-start mb-8">
      <div>
        <h3 class="text-xl font-bold flex items-center gap-2">
          <GraficProgressIcon class="w-20 h-20 text-purple-600 dark:text-purple-400" />
          Desempenho Analítico
        </h3>

        <p class="text-sm text-neutral-600 dark:text-neutral-400">
          Evolução das Notas
        </p>
      </div>

      <span
        class="
          text-sm font-semibold
          px-4 py-1.5 rounded-full
          bg-purple-100 text-purple-600
          dark:bg-purple-900/40 dark:text-purple-300
        "
      >
        +{evolutionTotal} pontos
      </span>
    </div>

    {/* ---------------- GRÁFICO ---------------- */}

    <div class="mb-10">
      <ScoreEvolutionChart
        data={chartData}
        year={currentYear}
        month={currentMonth}
      />
    </div>

    {/* ---------------- COMPETÊNCIAS ---------------- */}

    <div class="mt-10">
      <h4 class="font-semibold mb-5 text-neutral-800 dark:text-neutral-200">
        Progresso por Competências
      </h4>

      <div class="space-y-6">
        {competencies.map((comp) => (
          <CompetencyBar
            label={comp.label}
            value={comp.value}
            max={comp.max}
          />
        ))}
      </div>
    </div>

    {/* ---------------- DIVISOR ---------------- */}

    <div class="my-8 border-t border-neutral-200 dark:border-[#1F2A44]" />

    {/* ---------------- PROGRESSO GERAL ---------------- */}

    <div>
      <div class="flex justify-between items-center mb-3">
        <h4 class="font-semibold text-neutral-800 dark:text-neutral-200">
          Progresso Geral
        </h4>

        <span
          class="
            text-2xl font-bold
            bg-linear-to-r from-purple-500 to-cyan-400
            bg-clip-text text-transparent
          "
        >
          {overallProgress}%
        </span>
      </div>

      <ProgressBar percentage={overallProgress} height="12px" />

      <p class="text-sm mt-4 text-neutral-600 dark:text-neutral-400">
        Você está muito perto da excelência! Continue praticando para
        maximizar todas as competências.
      </p>
    </div>

  </div>
</section>