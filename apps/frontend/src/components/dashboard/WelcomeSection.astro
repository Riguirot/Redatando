---
import RobotMascot from "../../icons/RobotMascot.svg";

interface Props {
  studentName: string;
  subtitle: string;
}

const { studentName, subtitle } = Astro.props;
---

<section class="mb-12">

  <div class="animate-in">

    {/* BLOCO TÍTULO + ROBÔ */}
    <div class="flex items-center gap-8">

      {/* TEXTO */}
      <div>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white">
          Olá, {studentName}
        </h2>

        <p class="text-lg text-slate-400 mt-4">
          {subtitle}
        </p>
      </div>

      {/* ROBÔ MASCOTE */}
      <RobotMascot 
        class="w-34 h-34 md:w-60 md:h-60 shrink-0" 
      />

    </div>

  </div>

  {/* NEXT STEP CARD */}
<div
  class="
    relative overflow-hidden mt-10
    p-6 rounded-2xl
    transition-all duration-300

    /* LIGHT MODE */
    bg-white
    border border-purple-200
    shadow-sm
    hover:shadow-md
    hover:border-purple-300
    hover:-translate-y-0.5

    /* DARK MODE */
    dark:bg-linear-to-r
    dark:from-purple-900
    dark:via-purple-800
    dark:to-cyan-900
    dark:border-purple-600/40
    dark:shadow-lg
    dark:shadow-purple-900/40
    dark:hover:shadow-purple-500/30
  "
>
  <div class="flex items-start justify-between gap-6">

    <div class="flex-1">

      {/* Label */}
      <div class="flex items-center gap-2 mb-2">
        <span class="text-purple-500 dark:text-purple-300">⚡</span>
        <span class="text-sm font-semibold text-purple-600 dark:text-purple-300">
          Próximo Passo
        </span>
      </div>

      {/* Title */}
      <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-1">
        Envie uma redação essa semana
      </h3>

      {/* Description */}
      <p class="text-sm text-slate-600 dark:text-slate-300">
        Mantenha sua evolução praticando regularmente. Você está no caminho certo!
      </p>

    </div>

    {/* CTA */}
    <a
      href="/enviar"
      class="
        px-5 py-2 rounded-xl
        bg-linear-to-r
        from-purple-500
        to-cyan-500
        text-white text-sm font-medium
        hover:opacity-90
        transition
        whitespace-nowrap
      "
    >
      Enviar agora
    </a>

  </div>
</div>

</section>